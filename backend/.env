# ============================================================
# TrustNaija - Environment Configuration
# ============================================================

# Server Configuration
HOST=0.0.0.0
PORT=8080
ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgresql://trustnaija_user:strongpassword@localhost:5432/trustnaija
DATABASE_MAX_CONNECTIONS=10

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY_HOURS=24

# Termii SMS Configuration (Nigerian SMS Provider)
TERMII_API_KEY=your-termii-api-key-here
TERMII_BASE_URL=https://api.ng.termii.com/api
TERMII_SENDER_ID=TrustNaija
TERMII_CHANNEL=generic

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS_PER_MINUTE=30
USSD_RATE_LIMIT_PER_HOUR=10

# Risk Scoring Configuration
RISK_SCORE_HIGH_THRESHOLD=70
RISK_SCORE_MEDIUM_THRESHOLD=40

# Admin Configuration
ADMIN_API_KEY=your-admin-api-key-change-this-in-production

# Logging Configuration
RUST_LOG=trustnaija=debug,tower_http=debug,axum=trace

